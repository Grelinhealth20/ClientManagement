# ─────────────────────────────────────────────────────────────
# Grelin Health — Environment Configuration TEMPLATE
#
# Copy this file to `.env` and fill in real values, OR set these same keys in
# Vercel under Project → Settings → Environment Variables (Production + Preview).
# All values are validated at runtime by src/lib/env.js — a missing or malformed
# variable fails fast with a clear, aggregated error instead of a cryptic 500.
# Never commit real secrets to source control.
# ─────────────────────────────────────────────────────────────

# ── MySQL database (required) ────────────────────────────────
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
# Optional: pool size per serverless instance (default 5). Keep small on serverless.
DB_CONNECTION_LIMIT=5

# ── JWT signing secret (required, min 32 chars) ──────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-char-min-random-secret

# ── AES-256-GCM field-encryption key (required, exactly 64 hex chars = 32 bytes)
# Generate: openssl rand -hex 32
# WARNING: rotating this key makes previously encrypted fields undecryptable.
ENCRYPTION_KEY=replace-with-64-hex-characters

# ── Bootstrap Super Admin (optional; seeded on first DB init) ─
# Seeding runs only when both EMAIL and PASSWORD are set.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password
SUPER_ADMIN_NAME=Super Admin

# ── Session lifetime in hours (optional, default 12) ─────────
SESSION_TTL_HOURS=12
